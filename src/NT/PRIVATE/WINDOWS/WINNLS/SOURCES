MAJORCOMP=nlsapi
MINORCOMP=

TARGETNAME=nlslib
TARGETPATH=..\obj
TARGETTYPE=LIBRARY

# MicroNT: -D_NTSYSTEM_ — section.c / tables.c call Csr* primitives
# (BasepNlsPreserveSection LPC, BasepNlsCreateSortSection LPC).  Same
# rationale as in BASE/CLIENT/SOURCES.INC: without it the consumer
# .obj files emit `call [__imp__CsrFoo]` and the linker can't satisfy
# them.  With it they emit direct calls resolved by csrstub.obj
# (which gets linked into kernel32 alongside this lib).
C_DEFINES=$(C_DEFINES) -DUNICODE -D_KERNEL32_ -D_NTSYSTEM_

INCLUDES=..\inc;..\base\inc

SOURCES=init.c       \
        section.c    \
        tables.c     \
        util.c       \
        datetime.c   \
        enum.c       \
        getloc.c     \
        map.c        \
        mbcs.c       \
        number.c     \
        string.c     \
        ansi.c
