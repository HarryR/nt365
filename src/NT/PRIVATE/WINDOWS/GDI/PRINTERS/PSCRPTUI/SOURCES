MAJORCOMP=windows
MINORCOMP=pscript

TARGETNAME=pscrptui
TARGETPATH=$(BASEDIR)\public\sdk\lib
TARGETTYPE=DYNLINK
LINKLIBS=$(BASEDIR)\public\sdk\lib\*\libcntpr.lib
TARGETLIBS=..\lib\obj\*\libprt.lib              \
           ..\pslib\obj\*\pslib.lib             \
           $(BASEDIR)\public\sdk\lib\*\user32.lib      \
           $(BASEDIR)\public\sdk\lib\*\kernel32.lib    \
           $(BASEDIR)\public\sdk\lib\*\winspool.lib    \
           $(BASEDIR)\public\sdk\lib\*\gdi32.lib       \
           $(BASEDIR)\public\sdk\lib\*\shell32.lib     \
           $(BASEDIR)\public\sdk\lib\*\htui.lib

DLLENTRY=DllInitialize

INCLUDES=..\lib;..\pscript;..\..\..\inc;..\..\inc;..\pslib

NTLEGO=1
NTPROFILEINPUT=yes

SOURCES=initdll.c   \
	pscrptui.c  \
        quryprnt.c  \
        document.c  \
        halftone.c  \
        ttfonts.c   \
        devcaps.c   \
        help.c      \
        pscrptui.rc

UMTYPE=console
UMTEST=trui
UMLIBS= $(BASEDIR)\public\sdk\lib\*\gdi32.lib	  \
        $(BASEDIR)\public\sdk\lib\*\user32.lib     \
        $(BASEDIR)\public\sdk\lib\*\kernel32.lib     \
	.\obj\*\pscrptui.lib

C_DEFINES=-DUNICODE -DSTRICT
